  "description": "Con-Nav-Item-backend - 个人导航站后端",
  "repository": "https://github.com/zczy-k/Con-Nav-Item",
  "license": "MIT",
  "main": "app.js",
  "overrides": {
    "@tootallnate/once": "^3.0.1",
